# ============================================================
# 最小可运行 .env 模板
# ============================================================
# 运行时最少依赖两类配置：
# 1. provider / model / voice / thinking → config/app_config.json（或前端系统配置页）
# 2. API key / endpoint / 本地工具路径 → .env
#
# 当前代码下，最快跑通优先使用通用变量：
#   - LLM_API_KEY / LLM_API_URL
#   - TTS_API_KEY / TTS_API_URL
#   - VISION_API_KEY / VISION_API_URL / VISION_MODEL
#
# 关键约定：
# - LLM_API_URL 必须是完整的 /chat/completions 地址
# - TTS_API_URL 填 provider 的 base URL（例如 .../v1）
# - VISION_API_URL 必须是完整的 /chat/completions 地址
# - 如果同时设置 provider 专用变量，它们优先级高于通用变量
# ============================================================

# ---- 最小可运行配置（推荐） ----
LLM_API_KEY=sk-your-llm-key
LLM_API_URL=https://api.deepseek.com/chat/completions

TTS_API_KEY=your-tts-key
TTS_API_URL=https://api.xiaomimimo.com/v1

VISION_API_KEY=your-vision-key
VISION_API_URL=https://api.xiaomimimo.com/v1/chat/completions
VISION_MODEL=mimo-v2.5

# ---- 控制面网络配置（可选） ----
# 默认只监听本机；如需局域网访问，改为 0.0.0.0
# CONTROL_PLANE_HOST=0.0.0.0
# CONTROL_PLANE_PORT=17890
#
# 如需跨域访问（如前端在 5173 或其他机器），用逗号分隔多个来源
# 默认已包含 http://localhost:5173 和 http://localhost:17890
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:17890

# ---- Windows 可选：本地 ffmpeg / ffprobe 路径 ----
# FFMPEG_PATH=tools\bin\ffmpeg.exe
# FFPROBE_PATH=tools\bin\ffprobe.exe

# ---- 高级覆盖（可选） ----
# 如果需要固定到某个 provider，或并行配置多 provider，再使用下面这些变量。
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
#
# KIMI_API_KEY=sk-your-kimi-key
# KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions
#
# MIMO_API_KEY=your-mimo-key
# MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
#
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_GROUP_ID=your-minimax-group-id
# MINIMAX_TTS_URL=https://api-bj.minimaxi.com/v1/t2a_v2
#
# XIAOMI_VISION_API_KEY=your-xiaomi-vision-key
# XIAOMI_VISION_API_URL=https://api.xiaomimimo.com/v1/chat/completions
# XIAOMI_VISION_MODEL=mimo-v2.5
