LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=disabled

TTS_PROVIDER=mimo
MIMO_API_KEY=sk-your-mimo-key
MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_FALLBACK_MODEL=mimo-v2-tts
MIMO_TTS_VOICE=mimo_default
MIMO_TTS_FALLBACK_VOICE=default_zh
MIMO_TTS_STYLE=自然 清晰 适合短视频带货口播
MIMO_AUDIO_FORMAT=mp3

# Legacy fallback providers. Keep these only if you intentionally switch back.
KIMI_API_KEY=sk-your-kimi-key
KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions
KIMI_MODEL=moonshot-v1-8k
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id
MINIMAX_TTS_URL=https://api-bj.minimaxi.com/v1/t2a_v2
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_VOICE_ID=male-qn-qingse
MINIMAX_FALLBACK_VOICE_ID=Male-ZN-macong
MINIMAX_VOICE_SPEED=1.15
MINIMAX_VOICE_VOL=1.0
MINIMAX_VOICE_PITCH=0
MINIMAX_VOICE_EMOTION=calm
MINIMAX_AUDIO_SAMPLE_RATE=32000
MINIMAX_AUDIO_BITRATE=128000
MINIMAX_AUDIO_FORMAT=mp3
MINIMAX_AUDIO_CHANNEL=1

# Vision (multimodal) — 使用兼容 OpenAI Chat Completions 格式的 API。
# 当前选择 Xiaomi，请填入实际的 endpoint 和 model 名称。
VISION_PROVIDER=xiaomi
XIAOMI_VISION_API_KEY=your-xiaomi-vision-key
XIAOMI_VISION_API_URL=https://your-xiaomi-vision-endpoint/v1/chat/completions
XIAOMI_VISION_MODEL=your-model-name

# ============================================================
# 媒体工具路径配置
# ============================================================
# 支持两种配置方式：
#   1. 相对路径（推荐，方便跨平台部署）：相对于项目根目录
#   2. 绝对路径：适用于自定义安装位置
#
# 如果不设置，代码会根据操作系统自动选择默认值：
#   - macOS: /opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
#   - Windows: tools/bin/ffmpeg.exe（相对于项目根目录）
# ============================================================

# 相对路径配置（推荐，macOS 和 Windows 通用）
FFMPEG_PATH=tools/bin/ffmpeg
FFPROBE_PATH=tools/bin/ffprobe
WHISPER_PATH=tools/bin/whisper-cli
MODEL_PATH=tools/models/ggml-small.bin

# macOS 绝对路径（如果使用 Homebrew 安装）
# FFMPEG_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffprobe
# WHISPER_PATH=/opt/homebrew/bin/whisper-cli
# MODEL_PATH=/opt/homebrew/share/whisper-models/ggml-small.bin

# Windows 绝对路径（如果使用自定义安装）
# FFMPEG_PATH=D:\剪辑2.0\tools\bin\ffmpeg.exe
# FFPROBE_PATH=D:\剪辑2.0\tools\bin\ffprobe.exe
# WHISPER_PATH=D:\剪辑2.0\tools\bin\whisper-cli.exe
# MODEL_PATH=D:\剪辑2.0\tools\models\ggml-small.bin

COVER_FONT_PATH=C:\Windows\Fonts\simhei.ttf
BATCH_DIRECTION_FILE=.runtime_batch_direction.txt
